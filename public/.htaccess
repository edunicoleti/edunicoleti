<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /
  
  # Serve existing files and directories natively (allows /cristalpocos to work seamlessly)
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  
  # Se o arquivo/diretório não existir, direciona as rotas para o SPA (ex: /proposta/preamar)
  RewriteRule ^ index.html [QSA,L]
</IfModule>
